#!/usr/bin/env php
<?php

declare(strict_types=1);

use Foundation\Providers\ConsoleFoundationServiceProvider;
use Maduser\Argon\Container\ArgonContainer;
use Maduser\Argon\Prophecy\Argon;

require dirname(__DIR__) . '/vendor/autoload.php';

Argon::prophecy(static function (ArgonContainer $container): void {
    $container->register(ConsoleFoundationServiceProvider::class);
});

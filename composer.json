{
  "name": "maduser/argon-skeleton",
  "description": "Minimal application skeleton for the Argon runtime stack.",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Julien Duseyau",
      "email": "julien.duseyau@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "maduser/argon-console": "^1.0",
    "maduser/argon-error": "^1.0",
    "maduser/argon-http": "^1.0",
    "maduser/argon-http-message": "^1.0",
    "maduser/argon-middleware": "^1.0",
    "maduser/argon-prophecy": "^1.0.2",
    "maduser/argon-routing": "^1.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Foundation\\": "foundation/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "console": "php bin/console",
    "serve": "php -S 127.0.0.1:8098 server.php",
    "test": "vendor/bin/phpunit",
    "check": "find foundation src bootstrap config public routes tests -type f -name '*.php' -print0 | xargs -0 -n1 php -l && php -l bin/console && php -l server.php && composer test"
  }
}
